# ============================================================
# strawberry_vla_pro 环境配置
# 复制为 .env 并修改为你的实际路径:  cp .env.example .env
# ============================================================

# Isaac Sim 5.1.0 安装目录（包含 python.sh）
ISAAC_SIM_DIR=/path/to/isaac-sim

# 项目根目录（clone 下来的位置）
PROJECT_DIR=/path/to/strawberry_vla_pro

# checkpoint 存放目录（训练产出，可以是外置硬盘）
CHECKPOINT_DIR=/path/to/checkpoints
